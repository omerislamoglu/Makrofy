# Firebase — copy this file to .env and fill in your project values.
# Get these from https://console.firebase.google.com → Project Settings → General → Your apps

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# RevenueCat — optional. Get from https://app.revenuecat.com → API Keys.
# If left empty, subscription purchase/restore features are disabled safely;
# auth, login/register/logout, and the rest of the app still work.
# Use the Apple API key for iOS, or the public app-specific key.
VITE_REVENUECAT_API_KEY=
